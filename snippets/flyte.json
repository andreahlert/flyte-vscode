{
  "Flyte TaskEnvironment": {
    "prefix": "fenv",
    "body": [
      "${1:env} = flyte.TaskEnvironment(",
      "    name=\"${2:my-pipeline}\",",
      "    image=\"${3:auto}\",",
      "    resources=flyte.Resources(${4:cpu=1, memory=\"2Gi\"}),",
      ")"
    ],
    "description": "Create a Flyte TaskEnvironment"
  },
  "Flyte Task": {
    "prefix": "ftask",
    "body": [
      "@${1:env}.task",
      "async def ${2:my_task}(${3:input: str}) -> ${4:str}:",
      "    ${0:pass}"
    ],
    "description": "Create an async Flyte task"
  },
  "Flyte AppEnvironment": {
    "prefix": "fapp",
    "body": [
      "${1:app} = flyte.app.AppEnvironment(",
      "    name=\"${2:my-app}\",",
      "    port=${3:8080},",
      "    resources=flyte.Resources(${4:cpu=1, memory=\"2Gi\"}),",
      ")"
    ],
    "description": "Create a Flyte AppEnvironment"
  },
  "Flyte Resources": {
    "prefix": "fres",
    "body": [
      "flyte.Resources(",
      "    cpu=${1:1},",
      "    memory=\"${2:2Gi}\",",
      "    ${3:gpu=\"${4:T4:1}\",}",
      ")"
    ],
    "description": "Create Flyte Resources"
  },
  "Flyte Run": {
    "prefix": "frun",
    "body": [
      "if __name__ == \"__main__\":",
      "    flyte.run(${1:my_task}(${2:}))"
    ],
    "description": "Run a Flyte task locally"
  },
  "Flyte Deploy": {
    "prefix": "fdeploy",
    "body": [
      "if __name__ == \"__main__\":",
      "    flyte.deploy(${1:my_task}(${2:}))"
    ],
    "description": "Deploy a Flyte task"
  },
  "Flyte Cache": {
    "prefix": "fcache",
    "body": [
      "flyte.Cache(",
      "    behavior=\"${1|auto,override,disable|}\",",
      "    ignored_inputs=(\"${2:seed}\",),",
      ")"
    ],
    "description": "Create Flyte Cache configuration"
  },
  "Flyte Trigger": {
    "prefix": "ftrigger",
    "body": [
      "flyte.Trigger(",
      "    name=\"${1:my-trigger}\",",
      "    automation=flyte.${2|Cron(expression=\"${3:0 * * * *}\"),FixedRate(interval_minutes=${4:60})|},",
      ")"
    ],
    "description": "Create a Flyte Trigger"
  },
  "Flyte Image": {
    "prefix": "fimage",
    "body": [
      "flyte.Image.from_debian_base()",
      "    .with_pip_packages(\"${1:pandas}\", \"${2:numpy}\")"
    ],
    "description": "Create a Flyte Image with pip packages"
  },
  "Flyte Map": {
    "prefix": "fmap",
    "body": [
      "results = await flyte.map(${1:my_task}, ${2:items})"
    ],
    "description": "Map a task over inputs"
  },
  "Flyte Group": {
    "prefix": "fgroup",
    "body": [
      "with flyte.group(\"${1:group-name}\"):",
      "    ${0:pass}"
    ],
    "description": "Create a Flyte task group"
  },
  "Flyte Trace": {
    "prefix": "ftrace",
    "body": [
      "@flyte.trace",
      "async def ${1:traced_fn}(${2:}) -> ${3:str}:",
      "    ${0:pass}"
    ],
    "description": "Decorate a function with Flyte trace"
  },
  "Flyte Secret": {
    "prefix": "fsecret",
    "body": [
      "flyte.Secret(\"${1:my-secret}\", as_env_var=\"${2:MY_SECRET}\")"
    ],
    "description": "Reference a Flyte secret"
  }
}
